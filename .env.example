# ──────────────────────────────────────────────
# Defence FL Platform — Environment Variables
# Copy to .env and fill in your values.
# ──────────────────────────────────────────────

# ── Security ──
SECRET_KEY=replace-with-a-long-random-secret-key
# Generate a secure key with: python -c "import secrets; print(secrets.token_hex(len))"

# ── Database ───────────────────────────────────
# Used directly by docker-compose to build DATABASE_URL for the backend
# container (postgresql://POSTGRES_USER:POSTGRES_PASSWORD@db:5432/POSTGRES_DB).
POSTGRES_USER=fluser
POSTGRES_PASSWORD=replace-with-a-strong-database-password
POSTGRES_DB=flplatform

# ── Backend ────────────────────────────────────
DEBUG=false

# ── Default Admin (required, no fallback) ──
DEFAULT_ADMIN_EMAIL=replace-with-your-admin-email
DEFAULT_ADMIN_PASSWORD=replace-with-your-admin-password

# ── Frontend (set if not using Nginx proxy) ───
VITE_API_BASE_URL=http://localhost:8000
